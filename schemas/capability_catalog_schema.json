

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CapabilityCatalog",
  "type": "object",
  "required": ["version", "capabilities"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "family",
          "description",
          "input_types",
          "output_types",
          "examples"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "sense",
              "read",
              "filter",
              "detect",
              "infer",
              "compare",
              "decide",
              "act",
              "notify",
              "store",
              "schedule"
            ]
          },
          "family": {
            "type": "string",
            "enum": [
              "acquisition",
              "processing",
              "decision_execution",
              "interaction_persistence"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "input_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "output_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}