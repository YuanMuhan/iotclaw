
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedTaskSpec",
  "type": "object",
  "required": ["target", "inputs", "outputs"],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "remarks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": ["user", "device", "system", "external"]
          }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "latency": {
          "type": "string"
        },
        "privacy": {
          "type": "string"
        },
        "energy": {
          "type": "string"
        },
        "network": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "default": {}
    }
  },
  "additionalProperties": false
}